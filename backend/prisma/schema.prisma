generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  nickname String @unique
  password String
  quests Quest[]
}

model Quest {
  id String @id @default(uuid())
  userId String
  startNodeId String @unique
  title String
  description String

  nodes Node[] @relation("QuestNodes")
  startNode Node @relation("StartNode", fields: [startNodeId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Node {
  id String @id @default(uuid())
  questId String
  title String
  description String
  positionX String
  positionY String

  edgesFrom Edge[] @relation("from")
  edgesTo Edge[] @relation("to")
  quest Quest @relation("QuestNodes",fields: [questId], references: [id])
  startForQuest Quest? @relation("StartNode")
}

model Edge {
  id String @id @default(uuid())
  nodeFromId String
  nodeToId String
  conditions Json?

  nodeFrom Node @relation("from", fields: [nodeFromId], references: [id])
  nodeTo Node @relation("to", fields: [nodeToId], references: [id])
}

